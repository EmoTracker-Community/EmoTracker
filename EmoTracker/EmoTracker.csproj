<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <ProjectGuid>{37EF8519-4426-455F-9D23-292839365EE0}</ProjectGuid>
    <OutputType Condition="'$(TargetFramework)' == 'net8.0-windows'">WinExe</OutputType>
    <OutputType Condition="'$(TargetFramework)' == 'net8.0'">Exe</OutputType>
    <RootNamespace>EmoTracker</RootNamespace>
    <AssemblyName>EmoTracker</AssemblyName>
    <TargetFrameworks>net8.0-windows;net8.0</TargetFrameworks>
    <UseWpf Condition="'$(TargetFramework)' == 'net8.0-windows'">true</UseWpf>
    <ApplicationIcon>emohead_icon_transparent_7h3_icon.ico</ApplicationIcon>
    <ApplicationManifest Condition="'$(TargetFramework)' == 'net8.0-windows'">app.manifest</ApplicationManifest>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <AutoGenerateBindingRedirects Condition="'$(TargetFramework)' == 'net8.0-windows'">true</AutoGenerateBindingRedirects>
  </PropertyGroup>

  <!-- Define WINDOWS for the Windows target -->
  <PropertyGroup Condition="$(TargetFramework.Contains('-windows'))">
    <DefineConstants>$(DefineConstants);WINDOWS</DefineConstants>
  </PropertyGroup>

  <!-- PluginManager.cs is intentionally excluded from compilation -->
  <ItemGroup>
    <Compile Remove="PluginManager.cs" />
  </ItemGroup>

  <!-- Binary resources embedded in the assembly -->
  <ItemGroup>
    <Resource Include="emohead_icon_transparent_7h3_icon.ico" />
    <Resource Include="emotracker_icon.ico" />
    <Resource Include="release_notes.txt" />
    <Resource Include="Resources\**\*" />
  </ItemGroup>

  <!-- Windows-only native assembly references -->
  <ItemGroup Condition="$(TargetFramework.Contains('-windows'))">
    <Reference Include="ConnectorLib">
      <HintPath>..\External\ConnectorLib\ConnectorLib.dll</HintPath>
      <SpecificVersion>False</SpecificVersion>
    </Reference>
    <Reference Include="ConnectorLib.sd2snes">
      <HintPath>..\External\ConnectorLib\ConnectorLib.sd2snes.dll</HintPath>
      <SpecificVersion>False</SpecificVersion>
    </Reference>
    <Reference Include="PresentationFramework.Aero" />
    <PackageReference Include="System.ComponentModel.Composition" Version="4.7.0" />
    <PackageReference Include="System.Speech" Version="8.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\EmoTracker.Core\EmoTracker.Core.csproj" />
    <ProjectReference Include="..\EmoTracker.Data\EmoTracker.Data.csproj" />
    <ProjectReference Include="..\EmoTracker.UI\EmoTracker.UI.csproj" />
  </ItemGroup>

  <!-- NDI is Windows-only -->
  <ItemGroup Condition="$(TargetFramework.Contains('-windows'))">
    <ProjectReference Include="..\External\NDI\NDILibDotNet2\NDILibDotNet2.csproj" />
  </ItemGroup>

  <!-- WPF-only packages -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows'">
    <PackageReference Include="Markdig.Wpf" Version="0.5.0.1" />
    <PackageReference Include="WpfScreenHelper" Version="2.1.1" />
  </ItemGroup>

  <!-- Avalonia packages (cross-platform target) -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
    <PackageReference Include="Avalonia" Version="11.2.7" />
    <PackageReference Include="Avalonia.Desktop" Version="11.2.7" />
    <PackageReference Include="Avalonia.Themes.Fluent" Version="11.2.7" />
    <PackageReference Include="Avalonia.Xaml.Behaviors" Version="11.2.7" />
  </ItemGroup>

  <!-- Shared packages (both targets) -->
  <ItemGroup>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
    <PackageReference Include="Serilog" Version="4.3.1" />
    <PackageReference Include="Serilog.Sinks.Console" Version="6.1.1" />
    <PackageReference Include="Serilog.Sinks.File" Version="7.0.0" />
    <PackageReference Include="TwitchLib" Version="3.5.3" />
    <PackageReference Include="WebSocketSharp" Version="1.0.3-rc11" />
  </ItemGroup>

  <!--
    Exclude WPF-dependent and Windows-only source from the cross-platform net8.0 target.
    Avalonia equivalents (*.axaml / *.axaml.cs) are included via the AvaloniaXaml glob below.
  -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
    <!-- App entry point and main window (WPF) — replaced by App.axaml.cs / MainWindow.axaml.cs -->
    <Compile Remove="App.xaml.cs" />
    <Page Remove="App.xaml" />
    <Compile Remove="MainWindow.xaml.cs" />
    <Page Remove="MainWindow.xaml" />
    <!-- WPF code-behind files for UI controls — replaced by *.axaml.cs counterparts -->
    <Compile Remove="UI\**\*.xaml.cs" />
    <Page Remove="UI\**\*.xaml" />
    <!-- Update helper (WPF-dependent) -->
    <Compile Remove="Update\**\*.cs" />
    <!-- AutoTracker — requires Windows-only ConnectorLib -->
    <Compile Remove="Extensions\AutoTracker\**\*.cs" />
    <Page Remove="Extensions\AutoTracker\**\*.xaml" />
    <!-- BontaMultiworld — requires Windows-only ConnectorLib -->
    <Compile Remove="Extensions\BontaMultiworld\**\*.cs" />
    <Page Remove="Extensions\BontaMultiworld\**\*.xaml" />
    <!-- NDI — Windows-only -->
    <Compile Remove="Extensions\NDI\**\*.cs" />
    <Page Remove="Extensions\NDI\**\*.xaml" />
    <!-- NoteTaking WPF code-behind replaced by axaml.cs -->
    <Compile Remove="Extensions\NoteTaking\**\*.xaml.cs" />
    <Page Remove="Extensions\NoteTaking\**\*.xaml" />
    <!-- Twitch WPF code-behind replaced by axaml.cs -->
    <Compile Remove="Extensions\Twitch\**\*.xaml.cs" />
    <Page Remove="Extensions\Twitch\**\*.xaml" />
    <!-- VariantSwitcher WPF code-behind replaced by axaml.cs -->
    <Compile Remove="Extensions\VariantSwitcher\**\*.xaml.cs" />
    <Page Remove="Extensions\VariantSwitcher\**\*.xaml" />
    <!-- VoiceRecognition — requires Windows-only System.Speech -->
    <Compile Remove="Extensions\VoiceRecognition\**\*.cs" />
    <Page Remove="Extensions\VoiceRecognition\**\*.xaml" />
    <!-- Discord P/Invoke wrapper (Windows-only native SDK) -->
    <Compile Remove="Utility\DiscordRPC.cs" />
    <!-- WPF/Framework-dependent generated files -->
    <Compile Remove="Properties\Settings.Designer.cs" />
  </ItemGroup>

  <!-- Exclude Avalonia-only source from the net8.0-windows (WPF) target -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows'">
    <Compile Remove="Program.cs" />
    <Compile Remove="App.axaml.cs" />
    <Compile Remove="MainWindow.axaml.cs" />
    <Compile Remove="UI\**\*.axaml.cs" />
    <Compile Remove="Extensions\Twitch\**\*.axaml.cs" />
    <Compile Remove="Extensions\VariantSwitcher\**\*.axaml.cs" />
    <Compile Remove="Extensions\NoteTaking\**\*.axaml.cs" />
  </ItemGroup>

  <!-- Copy Windows-only native dependencies on net8.0-windows builds -->
  <Target Name="CopyNativeDependencies" AfterTargets="Build" Condition="$(TargetFramework.Contains('-windows'))">
    <Exec Command="xcopy /s /y &quot;$(SolutionDir)External\ConnectorLib\EasyHook32*&quot; &quot;$(TargetDir)&quot;" ContinueOnError="true" />
    <Exec Command="xcopy /s /y &quot;$(SolutionDir)External\ConnectorLib\EasyHook64*&quot; &quot;$(TargetDir)&quot;" ContinueOnError="true" />
    <Exec Command="xcopy /s /y &quot;$(SolutionDir)External\ConnectorLib\EasyLoad32*&quot; &quot;$(TargetDir)&quot;" ContinueOnError="true" />
    <Exec Command="xcopy /s /y &quot;$(SolutionDir)External\ConnectorLib\EasyLoad64*&quot; &quot;$(TargetDir)&quot;" ContinueOnError="true" />
    <Exec Command="xcopy /s /y &quot;$(SolutionDir)External\ConnectorLib\Connectors\bizhawk\*.*&quot; &quot;$(TargetDir)Connectors\bizhawk\&quot;" ContinueOnError="true" />
    <Exec Command="xcopy /s /y &quot;$(SolutionDir)External\ConnectorLib\Connectors\snes9x\*.*&quot; &quot;$(TargetDir)Connectors\snes9x\&quot;" ContinueOnError="true" />
    <Exec Command="xcopy /s /y &quot;$(SolutionDir)External\ConnectorLib\Connectors\common\*.*&quot; &quot;$(TargetDir)Connectors\bizhawk\&quot;" ContinueOnError="true" />
    <Exec Command="xcopy /s /y &quot;$(SolutionDir)External\ConnectorLib\Connectors\common\*.*&quot; &quot;$(TargetDir)Connectors\snes9x\&quot;" ContinueOnError="true" />
    <Exec Command="xcopy /s /y &quot;$(SolutionDir)External\Discord\*.*&quot; &quot;$(TargetDir)&quot;" ContinueOnError="true" />
    <Exec Command="xcopy /s /y &quot;$(SolutionDir)External\NDI\distrib\x86\*.*&quot; &quot;$(TargetDir)&quot;" ContinueOnError="true" />
    <Exec Command="xcopy /s /y &quot;$(SolutionDir)External\NDI\distrib\x64\*.*&quot; &quot;$(TargetDir)&quot;" ContinueOnError="true" />
  </Target>

  <Target Name="GenerateInstaller" AfterTargets="Build" Condition="'$(Configuration)' == 'Release' and $(TargetFramework.Contains('-windows'))">
    <Exec Command="&quot;C:\Program Files (x86)\Inno Setup 5\ISCC.exe&quot; &quot;$(SolutionDir)Installer\emotracker_setup.iss&quot;" ContinueOnError="true" />
  </Target>

</Project>
