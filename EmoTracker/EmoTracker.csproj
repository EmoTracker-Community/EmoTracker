<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <ProjectGuid>{37EF8519-4426-455F-9D23-292839365EE0}</ProjectGuid>
    <OutputType>WinExe</OutputType>
    <RootNamespace>EmoTracker</RootNamespace>
    <AssemblyName>EmoTracker</AssemblyName>
    <TargetFramework>net472</TargetFramework>
    <UseWpf>true</UseWpf>
    <ApplicationIcon>emohead_icon_transparent_7h3_icon.ico</ApplicationIcon>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <AutoGenerateBindingRedirects>true</AutoGenerateBindingRedirects>
  </PropertyGroup>

  <!-- PluginManager.cs is intentionally excluded from compilation -->
  <ItemGroup>
    <Compile Remove="PluginManager.cs" />
  </ItemGroup>

  <!-- Binary resources embedded in the assembly -->
  <ItemGroup>
    <Resource Include="emohead_icon_transparent_7h3_icon.ico" />
    <Resource Include="emotracker_icon.ico" />
    <Resource Include="release_notes.txt" />
    <Resource Include="Resources\**\*" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="ConnectorLib">
      <HintPath>..\External\ConnectorLib\ConnectorLib.dll</HintPath>
      <SpecificVersion>False</SpecificVersion>
    </Reference>
    <Reference Include="ConnectorLib.sd2snes">
      <HintPath>..\External\ConnectorLib\ConnectorLib.sd2snes.dll</HintPath>
      <SpecificVersion>False</SpecificVersion>
    </Reference>
    <Reference Include="PresentationFramework.Aero" />
    <Reference Include="System.ComponentModel.Composition" />
    <Reference Include="System.Speech" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\EmoTracker.Core\EmoTracker.Core.csproj" />
    <ProjectReference Include="..\EmoTracker.Data\EmoTracker.Data.csproj" />
    <ProjectReference Include="..\EmoTracker.UI\EmoTracker.UI.csproj" />
    <ProjectReference Include="..\External\NDI\NDILibDotNet2\NDILibDotNet2.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Markdig.Wpf" Version="0.5.0.1" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
    <PackageReference Include="Serilog" Version="4.3.1" />
    <PackageReference Include="Serilog.Sinks.Console" Version="6.1.1" />
    <PackageReference Include="Serilog.Sinks.File" Version="7.0.0" />
    <PackageReference Include="TwitchLib" Version="3.5.3" />
    <PackageReference Include="WebSocketSharp" Version="1.0.3-rc11" />
    <PackageReference Include="WpfScreenHelper" Version="2.1.1" />
  </ItemGroup>

  <Target Name="CopyNativeDependencies" AfterTargets="Build">
    <Exec Command="xcopy /s /y &quot;$(SolutionDir)External\ConnectorLib\EasyHook32*&quot; &quot;$(TargetDir)&quot;" ContinueOnError="true" />
    <Exec Command="xcopy /s /y &quot;$(SolutionDir)External\ConnectorLib\EasyHook64*&quot; &quot;$(TargetDir)&quot;" ContinueOnError="true" />
    <Exec Command="xcopy /s /y &quot;$(SolutionDir)External\ConnectorLib\EasyLoad32*&quot; &quot;$(TargetDir)&quot;" ContinueOnError="true" />
    <Exec Command="xcopy /s /y &quot;$(SolutionDir)External\ConnectorLib\EasyLoad64*&quot; &quot;$(TargetDir)&quot;" ContinueOnError="true" />
    <Exec Command="xcopy /s /y &quot;$(SolutionDir)External\ConnectorLib\Connectors\bizhawk\*.*&quot; &quot;$(TargetDir)Connectors\bizhawk\&quot;" ContinueOnError="true" />
    <Exec Command="xcopy /s /y &quot;$(SolutionDir)External\ConnectorLib\Connectors\snes9x\*.*&quot; &quot;$(TargetDir)Connectors\snes9x\&quot;" ContinueOnError="true" />
    <Exec Command="xcopy /s /y &quot;$(SolutionDir)External\ConnectorLib\Connectors\common\*.*&quot; &quot;$(TargetDir)Connectors\bizhawk\&quot;" ContinueOnError="true" />
    <Exec Command="xcopy /s /y &quot;$(SolutionDir)External\ConnectorLib\Connectors\common\*.*&quot; &quot;$(TargetDir)Connectors\snes9x\&quot;" ContinueOnError="true" />
    <Exec Command="xcopy /s /y &quot;$(SolutionDir)External\Discord\*.*&quot; &quot;$(TargetDir)&quot;" ContinueOnError="true" />
    <Exec Command="xcopy /s /y &quot;$(SolutionDir)External\NDI\distrib\x86\*.*&quot; &quot;$(TargetDir)&quot;" ContinueOnError="true" />
    <Exec Command="xcopy /s /y &quot;$(SolutionDir)External\NDI\distrib\x64\*.*&quot; &quot;$(TargetDir)&quot;" ContinueOnError="true" />
  </Target>

  <Target Name="GenerateInstaller" AfterTargets="Build" Condition="'$(Configuration)' == 'Release'">
    <Exec Command="&quot;C:\Program Files (x86)\Inno Setup 5\ISCC.exe&quot; &quot;$(SolutionDir)Installer\emotracker_setup.iss&quot;" ContinueOnError="true" />
  </Target>

</Project>
