<Window x:Class="EmoTracker.UI.AppUpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EmoTracker.UI"
        xmlns:update="clr-namespace:EmoTracker.Update"
        mc:Ignorable="d"
        Title="EmoTracker Update" Width="300" SizeToContent="Height" Background="#212121" Topmost="True" WindowStartupLocation="CenterOwner">
    <Grid DataContext="{Binding Source={x:Static update:AppUpdate.Instance}}" Margin="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Foreground="WhiteSmoke" TextWrapping="WrapWithOverflow">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Status}" Value="RunningLegacyApp">
                                <Setter Property="Text" Value="You are running a legacy version of EmoTracker.&#x0a;&#x0a;Pack downloads/updates are disabled, and you will no longer receive application updates.&#x0a;&#x0a;Please install the new version, and uninstall the old version.&#x0a;" />                                
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="CheckingForUpdate">
                                <Setter Property="Text" Value="Checking for update..." />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="UpdateAvailable">
                                <Setter Property="Text" Value="An application update is available!" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="NoUpdateAvailable">
                                <Setter Property="Text" Value="EmoTracker is up to date." />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="DownloadingUpdate">
                                <Setter Property="Text" Value="Downloading update..." />
                            </DataTrigger>                            
                            <DataTrigger Binding="{Binding Status}" Value="InstallingUpdate">
                                <Setter Property="Text" Value="Installing update..." />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="Error">
                                <Setter Property="Text" Value="An error has occurred" />
                            </DataTrigger>                            
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <ContentControl Grid.Row="2" MaxHeight="25">
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Status}" Value="CheckingForUpdate">
                                <DataTrigger.Setters>
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <ProgressBar IsIndeterminate="True"/>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger.Setters>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="InstallingUpdate">
                                <DataTrigger.Setters>
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <ProgressBar IsIndeterminate="True"/>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger.Setters>
                            </DataTrigger>                            
                            <DataTrigger Binding="{Binding Status}" Value="DownloadingUpdate">
                                <DataTrigger.Setters>
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <ProgressBar Maximum="100" Value="{Binding DownloadPercentage}"/>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger.Setters>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="RunningLegacyApp">
                                <DataTrigger.Setters>
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <Button Content="Download and Install Update" Command="{Binding DownloadAndInstallUpdateCommand}"/>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger.Setters>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="UpdateAvailable">
                                <DataTrigger.Setters>
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <Button Content="Download and Install Update" Command="{Binding DownloadAndInstallUpdateCommand}"/>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger.Setters>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>

        </Grid>
    </Grid>
</Window>
