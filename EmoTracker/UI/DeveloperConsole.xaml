<Window x:Class="EmoTracker.UI.DeveloperConsole"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EmoTracker.UI"
        xmlns:data="clr-namespace:EmoTracker.Data;assembly=EmoTracker.Data"
        mc:Ignorable="d"
        Title="Developer Console" Height="450" Width="800">
    <Grid Background="#212121">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <ScrollViewer Name="ConsoleScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl Name="ConsoleOutput" ItemsSource="{Binding LogOutput, Source={x:Static data:ScriptManager.Instance}}" Margin="5,10">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock FontFamily="Consolas" FontSize="12" Text="{Binding Text}" TextWrapping="Wrap" Foreground="{Binding Color}" Margin="5,2"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        <Grid Grid.Row="1" Background="#212121">
            <Button Content="Clear" Command="{Binding ClearLogCommand, Source={x:Static data:ScriptManager.Instance}}"/>
        </Grid>
    </Grid>
</Window>
