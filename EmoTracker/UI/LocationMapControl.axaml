<controls:ObservableUserControl Name="userControl"
             x:Class="EmoTracker.UI.LocationMapControl"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:EmoTracker.UI"
             xmlns:controls="clr-namespace:EmoTracker.UI.Controls;assembly=EmoTracker.UI"
             xmlns:converters="clr-namespace:EmoTracker.UI.Converters;assembly=EmoTracker.UI"
             xmlns:data="clr-namespace:EmoTracker.Data;assembly=EmoTracker.Data"
             xmlns:session="clr-namespace:EmoTracker.Data.Session;assembly=EmoTracker.Data"
             xmlns:locations="clr-namespace:EmoTracker.Data.Locations;assembly=EmoTracker.Data"
             xmlns:settings="clr-namespace:EmoTracker.Data.Settings;assembly=EmoTracker.Data">
    <UserControl.Resources>
        <ItemsPanelTemplate x:Key="HorizontalWrapPanel">
            <WrapPanel Orientation="Horizontal" />
        </ItemsPanelTemplate>
        <ItemsPanelTemplate x:Key="HorizontalStackPanel">
            <StackPanel Orientation="Horizontal" />
        </ItemsPanelTemplate>
        <ItemsPanelTemplate x:Key="VerticalStackPanel">
            <StackPanel Orientation="Vertical" />
        </ItemsPanelTemplate>
    </UserControl.Resources>

    <Grid IsHitTestVisible="True">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Location details popup (light-dismiss managed in code-behind to allow double-click) -->
        <Popup x:Name="LocationDetails" Placement="Bottom">
            <local:LocationControl x:Name="LocationDetailsContent" Margin="15">
                <local:LocationControl.Effect>
                    <DropShadowDirectionEffect BlurRadius="15" ShadowDepth="0" Opacity="0.8" />
                </local:LocationControl.Effect>
            </local:LocationControl>
        </Popup>

        <!-- Badge details popup (hover, no hit-testing) -->
        <Popup x:Name="BadgeDetails" Placement="Bottom" IsHitTestVisible="False"
               PlacementTarget="{Binding #userControl.BadgesTarget}">
            <Border BorderBrush="DarkGray" BorderThickness="3" Background="#c0212121" CornerRadius="5">
                <ItemsControl x:Name="BadgeItemsControl" Margin="5">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel MaxWidth="350" Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Image Source="{Binding ResolvedImage}"
                                   Margin="2" Width="32"
                                   RenderOptions.BitmapInterpolationMode="None" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </Popup>

        <Viewbox Name="ViewScaler" VerticalAlignment="Top" Grid.Row="0">
            <ItemsControl Name="MapsItemsControl" ItemsSource="{Binding Maps}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <!-- Orientation is set imperatively by code-behind (UpdateMapOrientation)
                             because bindings from inside ItemsPanelTemplate to ancestor controls
                             don't reliably resolve in Avalonia. -->
                        <StackPanel Name="MapsPanel" Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="locations:Map">
                        <Grid Name="MapHost" Margin="25,25">
                            <controls:InputMaskingImage Name="MapImage"
                                                        Source="{Binding Image.ResolvedImage, FallbackValue={x:Null}}"/>
                            <ItemsControl ItemsSource="{Binding Locations}" ClipToBounds="False">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas Width="{Binding #MapImage.Source.Size.Width}"
                                                Height="{Binding #MapImage.Source.Size.Height}"
                                                ClipToBounds="False"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerTheme>
                                    <ControlTheme TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}" />
                                        <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                    </ControlTheme>
                                </ItemsControl.ItemContainerTheme>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="locations:MapLocation">
                                        <Grid Name="MinifiedLocation" ClipToBounds="False">
                                            <Grid.IsVisible>
                                                <MultiBinding Converter="{x:Static converters:MapLocationVisibilityConverter.Instance}">
                                                    <Binding Path="ForceVisible" />
                                                    <Binding Path="ForceInvisible" />
                                                    <Binding Path="Location.HasVisibleSections" />
                                                    <Binding Path="Location.AccessibilityLevel" />
                                                    <Binding Path="Location.HasAvailableItems" />
                                                    <Binding Path="Location.BadgeItems.Count" />
                                                    <Binding Path="Location.NoteTakingSite.Empty" />
                                                    <Binding Path="Global.DisplayAllLocations" Source="{x:Static session:TrackerSession.Current}" />
                                                    <Binding Path="IsShiftPressed" RelativeSource="{RelativeSource AncestorType=local:LocationMapControl}" />
                                                </MultiBinding>
                                            </Grid.IsVisible>
                                            <Border BorderThickness="{Binding BorderThickness, Converter={x:Static converters:DoubleToThicknessConverter.Instance}}"
                                                    Width="{Binding Size}"
                                                    Height="{Binding Size}"
                                                    Canvas.Left="{Binding X}"
                                                    Canvas.Top="{Binding Y}"
                                                    Margin="{Binding Margin, Converter={x:Static converters:ThicknessConverter.Instance}}"
                                                    VerticalAlignment="Top"
                                                    HorizontalAlignment="Left"
                                                    BorderBrush="#212121"
                                                    Background="{Binding Location.AccessibilityLevel, Converter={x:Static converters:AccessibilityLevelToBrushConverter.Instance}}">
                                                <!-- Note indicator: shown when a location has notes -->
                                                <Viewbox Width="{Binding NoteIndicatorSize}"
                                                         Height="{Binding NoteIndicatorSize}"
                                                         StretchDirection="Both"
                                                         VerticalAlignment="Top"
                                                         HorizontalAlignment="Right"
                                                         Margin="{Binding NoteIndicatorMargin, Converter={x:Static converters:ThicknessConverter.Instance}}"
                                                         IsVisible="{Binding Location.NoteTakingSite.Empty, Converter={x:Static converters:BoolInverseConverter.Instance}}">
                                                    <Border Background="#000000" CornerRadius="2">
                                                        <TextBlock Name="Icon"
                                                                   FontFamily="{StaticResource FontAwesome5Free}"
                                                                   Text="&#xf044;"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{Binding Status_Generic_Active, Source={x:Static settings:ApplicationColors.Instance}}"
                                                                   Margin="1" />
                                                    </Border>
                                                </Viewbox>
                                            </Border>

                                            <!-- Badges host: badge is centered on the alignment anchor point
                                                 of the blip (e.g. BottomRight = blip corner at Size/2, Size/2).
                                                 BadgeMargin encodes the computed offset; BadgeOffset shifts further. -->
                                            <ItemsControl ItemsSource="{Binding Location.BadgeItems}"
                                                          IsVisible="{Binding DataContext.BadgeSize, ElementName=MinifiedLocation, Converter={x:Static converters:NonZeroToBoolConverter.Instance}}"
                                                          VerticalAlignment="Top"
                                                          HorizontalAlignment="Left"
                                                          Margin="{Binding DataContext.BadgeMargin, ElementName=MinifiedLocation, Converter={x:Static converters:ThicknessConverter.Instance}}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Grid />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Viewbox Width="{Binding DataContext.BadgeSize, ElementName=MinifiedLocation}"
                                                                 Height="{Binding DataContext.BadgeSize, ElementName=MinifiedLocation}"
                                                                 StretchDirection="Both">
                                                            <Viewbox.RenderTransform>
                                                                <TranslateTransform X="{Binding OffsetX}" Y="{Binding OffsetY}" />
                                                            </Viewbox.RenderTransform>
                                                            <controls:InputMaskingImage
                                                                IsHitTestVisible="{Binding DataContext.EnableBadgeHitTest, ElementName=MinifiedLocation}"
                                                                Source="{Binding Image.ResolvedImage}" />
                                                        </Viewbox>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Viewbox>
    </Grid>
</controls:ObservableUserControl>
