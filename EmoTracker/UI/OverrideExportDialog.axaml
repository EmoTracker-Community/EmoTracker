<Window x:Class="EmoTracker.UI.OverrideExportDialog"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:EmoTracker.UI"
        Title="Export Overrides"
        Height="450"
        Width="800"
        WindowStartupLocation="CenterOwner">
    <!-- Layout uses DockPanel — not Grid — to avoid issue #70 where the
         ScrollViewer's content escaped the middle row of an
         "Auto,*,Auto" Grid and overlapped both the search bar and the
         Export Overrides button at the bottom. With DockPanel, the
         Top-docked search bar and Bottom-docked button claim their
         natural heights first; the ScrollViewer (LastChildFill = true,
         the default) gets exactly the remaining client area, and its
         content presenter clips correctly. -->
    <DockPanel Background="#212121">

        <!-- Search bar header (docked top) -->
        <Grid DockPanel.Dock="Top" Background="#252030">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <TextBlock Foreground="WhiteSmoke"
                       Text="Search Files"
                       VerticalAlignment="Center"
                       Margin="15,0,10,0" />

            <TextBox Grid.Column="1"
                     Padding="8,4,24,4"
                     CornerRadius="10"
                     FontSize="10"
                     Margin="5,5,10,5"
                     VerticalAlignment="Center"
                     VerticalContentAlignment="Center"
                     Text="{Binding FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>

        <!-- Export button (docked bottom). HorizontalContentAlignment=Center
             because the inner TextBlock would otherwise default to left-edge
             alignment within the stretched ContentControl. -->
        <Button DockPanel.Dock="Bottom"
                Click="ExportOverridesButton_Click"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center">
            <TextBlock Text="Export Overrides" Margin="0,5" />
        </Button>

        <!-- Records list (LastChildFill = remaining space). ClipToBounds
             on both the ScrollViewer and the inner ItemsControl is set
             defensively to ensure no descendant escapes the viewport even
             if a future template change introduces an oversize child. -->
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      ClipToBounds="True">
            <ItemsControl ItemsSource="{Binding Records}"
                          Margin="0,10,0,10"
                          ClipToBounds="True">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="10,2"
                              MinHeight="25"
                              Background="{Binding ExportOverride,
                                           Converter={x:Static local:OverrideExportDialog.ExportOverrideToBackgroundConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <CheckBox Grid.Column="0"
                                      IsChecked="{Binding ExportOverride}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,5,0" />

                            <Grid Grid.Column="1"
                                  Margin="5,5"
                                  MaxHeight="32">
                                <Viewbox StretchDirection="DownOnly">
                                    <Image Source="{Binding PreviewSource}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center" />
                                </Viewbox>
                            </Grid>

                            <TextBlock Grid.Column="2"
                                       Text="{Binding Path}"
                                       FontFamily="Consolas"
                                       Margin="5,0"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Background="Transparent"
                                       ToolTip.Tip="{Binding ToolTip}"
                                       Foreground="{Binding ExportOverride,
                                                    Converter={x:Static local:OverrideExportDialog.ExportOverrideToForegroundConverter}}" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</Window>
