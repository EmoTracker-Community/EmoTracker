<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:EmoTracker"
             xmlns:sessions="clr-namespace:EmoTracker.Data.Sessions;assembly=EmoTracker.Data"
             x:Class="EmoTracker.UI.StateTabStripControl"
             Name="TabStripRoot"
             mc:Ignorable="d"
             Background="#1A1A1A">

    <!-- Outer Grid lets EmptyHint overlay the strip when there are
         no states (UserControl needs a single root, and the empty-
         state placeholder sits as a sibling overlay rather than
         inside the dock). -->
    <Grid>

    <!-- Layout: dropdown docked to the right (always reachable, never
         scrolls); the rest of the strip width hosts a horizontally-
         scrollable ItemsControl for the tabs. The scrollbar itself is
         hidden — overflow tabs are reachable by mouse-wheel scroll
         (or the dropdown for jump-to-tab). DockPanel guarantees the
         docked Button sizes to its content first and the fill area
         takes the remaining width, regardless of how wide the inner
         StackPanel of tabs gets. -->
    <DockPanel LastChildFill="True">

        <!-- Right-side dropdown button: opens a flyout listing every
             open tab so the user can jump to any of them regardless
             of horizontal scroll position. The flyout's MenuItems are
             built in code-behind on each open so the list reflects
             the current OpenStates collection (and active-tab marker). -->
        <Button DockPanel.Dock="Right"
                Name="TabsDropdownButton"
                Background="#1A1A1A"
                BorderThickness="1,0,0,0"
                BorderBrush="#2A2A2A"
                Padding="10,0"
                VerticalAlignment="Stretch"
                Foreground="#CCCCCC"
                ToolTip.Tip="All open tabs"
                Click="OnTabsDropdownClicked">
            <TextBlock Text="▾"
                       FontSize="14"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="#CCCCCC" />
            <Button.Flyout>
                <MenuFlyout Placement="Bottom" />
            </Button.Flyout>
        </Button>

        <!-- Tab strip area (fill). The ScrollViewer keeps overflow
             tabs reachable via mouse-wheel without showing a visible
             scrollbar. -->
        <ScrollViewer Name="TabsScrollViewer"
                      HorizontalScrollBarVisibility="Hidden"
                      VerticalScrollBarVisibility="Disabled">
            <ItemsControl Name="TabsHost"
                          ItemsSource="{Binding #TabStripRoot.OpenStates}"
                          VerticalAlignment="Stretch">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="0" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="sessions:TrackerState">
                        <!-- Outer border carries the top accent (active tab gets a 2px
                             coloured top edge per VS Code style; inactive tabs no top
                             accent). Inner border gives the tab its body, padding,
                             click area, and right-edge separator. -->
                        <Border Name="TabBorder"
                                Padding="8,3"
                                BorderBrush="#2A2A2A"
                                BorderThickness="0,2,1,0"
                                Background="#1A1A1A"
                                PointerPressed="OnTabPointerPressed"
                                PointerReleased="OnTabPointerReleased"
                                PointerMoved="OnTabPointerMoved"
                                Tag="{Binding}">
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Open in New Window" Click="OnContextOpenInNewWindow" Tag="{Binding}" />
                                    <MenuItem Header="Save…" Click="OnContextSave" Tag="{Binding}" />
                                    <Separator />
                                    <MenuItem Header="Close" Click="OnContextClose" Tag="{Binding}" />
                                </ContextMenu>
                            </Border.ContextMenu>
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  VerticalAlignment="Center">
                                <!-- Phase 7.11 polish: modified-marker dot, visible
                                     only when this state has unsaved changes. -->
                                <TextBlock Grid.Column="0"
                                           Text="•"
                                           Foreground="#FFB454"
                                           FontSize="14"
                                           LineHeight="11"
                                           Margin="0,0,4,0"
                                           VerticalAlignment="Center"
                                           IsVisible="{Binding IsDirty}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Name, FallbackValue='(unnamed)'}"
                                           Foreground="#CCCCCC"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           MaxWidth="160"
                                           TextTrimming="CharacterEllipsis" />
                                <Button Grid.Column="2"
                                        Content="✕"
                                        FontSize="9"
                                        Margin="6,0,0,0"
                                        Padding="3,0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="#888"
                                        VerticalAlignment="Center"
                                        Click="OnCloseTab"
                                        Tag="{Binding}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>

    <!-- Empty-state placeholder, overlay -->
    <TextBlock Name="EmptyHint"
               Text="No states open — load a pack via the bottom bar"
               Foreground="#555"
               FontSize="10"
               VerticalAlignment="Center"
               HorizontalAlignment="Left"
               Margin="8,0"
               IsVisible="False" />

    </Grid>

</UserControl>
