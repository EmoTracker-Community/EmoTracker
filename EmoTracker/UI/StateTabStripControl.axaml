<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:EmoTracker"
             xmlns:sessions="clr-namespace:EmoTracker.Data.Sessions;assembly=EmoTracker.Data"
             x:Class="EmoTracker.UI.StateTabStripControl"
             Name="TabStripRoot"
             mc:Ignorable="d"
             Background="#1A1A1A"
             ClipToBounds="True">

    <!-- Layout: explicit Grid with two columns; ScrollViewer fills *,
         Button sized Auto on the right. ClipToBounds on the
         UserControl + ScrollViewer keeps the inner StackPanel of
         tabs from rendering past the column boundary. -->
    <Grid ClipToBounds="True">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Tab strip (column 0). HorizontalScrollBarVisibility=Hidden
             keeps the scrollbar invisible while still allowing the
             control to scroll horizontally via mouse wheel. -->
        <ScrollViewer Grid.Column="0"
                      Name="TabsScrollViewer"
                      HorizontalScrollBarVisibility="Hidden"
                      VerticalScrollBarVisibility="Disabled"
                      ClipToBounds="True">
            <ItemsControl Name="TabsHost"
                          ItemsSource="{Binding #TabStripRoot.OpenStates}"
                          VerticalAlignment="Stretch">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="0" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="sessions:TrackerState">
                        <Border Name="TabBorder"
                                Padding="8,3"
                                BorderBrush="#2A2A2A"
                                BorderThickness="0,2,1,0"
                                Background="#1A1A1A"
                                PointerPressed="OnTabPointerPressed"
                                PointerReleased="OnTabPointerReleased"
                                PointerMoved="OnTabPointerMoved"
                                Tag="{Binding}">
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Open in New Window" Click="OnContextOpenInNewWindow" Tag="{Binding}" />
                                    <MenuItem Header="Save…" Click="OnContextSave" Tag="{Binding}" />
                                    <Separator />
                                    <MenuItem Header="Close" Click="OnContextClose" Tag="{Binding}" />
                                </ContextMenu>
                            </Border.ContextMenu>
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  VerticalAlignment="Center">
                                <TextBlock Grid.Column="0"
                                           Text="•"
                                           Foreground="#FFB454"
                                           FontSize="14"
                                           LineHeight="11"
                                           Margin="0,0,4,0"
                                           VerticalAlignment="Center"
                                           IsVisible="{Binding IsDirty}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Name, FallbackValue='(unnamed)'}"
                                           Foreground="#CCCCCC"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           MaxWidth="160"
                                           TextTrimming="CharacterEllipsis" />
                                <Button Grid.Column="2"
                                        Content="✕"
                                        FontSize="9"
                                        Margin="6,0,0,0"
                                        Padding="3,0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="#888"
                                        VerticalAlignment="Center"
                                        Click="OnCloseTab"
                                        Tag="{Binding}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Right-side dropdown button (column 1, Auto-sized). Always
             pinned to the right; never participates in the tab
             scroller. The Popup is constructed and managed in code-
             behind to give us deterministic item population on
             every open (Avalonia's Button.Flyout has timing issues
             between Click event firing and flyout opening that left
             the menu empty). -->
        <Button Grid.Column="1"
                Name="TabsDropdownButton"
                Background="#1A1A1A"
                BorderThickness="1,0,0,0"
                BorderBrush="#2A2A2A"
                Padding="10,0"
                MinWidth="28"
                VerticalAlignment="Stretch"
                ToolTip.Tip="All open tabs"
                Click="OnTabsDropdownClicked">
            <TextBlock Text="▾"
                       FontSize="14"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="#CCCCCC" />
        </Button>

        <!-- Popup hosting the per-window tab list. Spans both columns
             so PlacementTarget=TabsDropdownButton anchors it under
             the dropdown. Children built in code-behind on each
             open. -->
        <Popup Name="TabsDropdownPopup"
               Placement="BottomEdgeAlignedRight"
               PlacementTarget="{Binding ElementName=TabsDropdownButton}"
               IsLightDismissEnabled="True">
            <Border Background="#222222"
                    BorderBrush="#3A3A3A"
                    BorderThickness="1"
                    Padding="0">
                <ItemsControl Name="TabsDropdownItems" />
            </Border>
        </Popup>

        <!-- Empty-state placeholder, overlay -->
        <TextBlock Name="EmptyHint"
                   Grid.Column="0"
                   Grid.ColumnSpan="2"
                   Text="No states open — load a pack via the bottom bar"
                   Foreground="#555"
                   FontSize="10"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Left"
                   Margin="8,0"
                   IsVisible="False" />
    </Grid>

</UserControl>
