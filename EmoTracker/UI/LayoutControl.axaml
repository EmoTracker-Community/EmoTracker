<UserControl x:Class="EmoTracker.UI.LayoutControl"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:app="clr-namespace:EmoTracker"
             xmlns:controls="clr-namespace:EmoTracker.UI.Controls;assembly=EmoTracker.UI"
             xmlns:converters="clr-namespace:EmoTracker.UI.Converters;assembly=EmoTracker.UI"
             xmlns:data="clr-namespace:EmoTracker.Data;assembly=EmoTracker.Data"
             xmlns:layout="clr-namespace:EmoTracker.Data.Layout;assembly=EmoTracker.Data"
             xmlns:local="clr-namespace:EmoTracker.UI">
    <UserControl.DataTemplates>

        <DataTemplate DataType="layout:LayoutReference">
            <Grid Width="{Binding Width, Converter={x:Static converters:NegativeToNaNDoubleConverter.Instance}}"
                  Height="{Binding Height, Converter={x:Static converters:NegativeToNaNDoubleConverter.Instance}}"
                  Margin="{Binding Margin}"
                  HorizontalAlignment="{Binding HorizontalAlignment, Converter={x:Static converters:TrivialEnumConverter.Instance}}"
                  VerticalAlignment="{Binding VerticalAlignment, Converter={x:Static converters:TrivialEnumConverter.Instance}}"
                  IsHitTestVisible="{Binding HitTestVisible}"
                  Effect="{Binding DropShadow, Converter={x:Static converters:BoolToDropShadowEffectConverter.Instance}}">
                <ContentControl Content="{Binding Layout.Root}" />
            </Grid>
        </DataTemplate>

        <!-- RecentPinnedLocations MUST be declared before ArrayPanel because it extends
             ArrayPanel — Avalonia picks the first DataType match, so the derived type wins. -->
        <DataTemplate DataType="layout:RecentPinnedLocations">
            <Grid Width="{Binding Width, Converter={x:Static converters:NegativeToNaNDoubleConverter.Instance}}"
                  Height="{Binding Height, Converter={x:Static converters:NegativeToNaNDoubleConverter.Instance}}"
                  Margin="{Binding Margin}"
                  HorizontalAlignment="{Binding HorizontalAlignment, Converter={x:Static converters:TrivialEnumConverter.Instance}}"
                  VerticalAlignment="{Binding VerticalAlignment, Converter={x:Static converters:TrivialEnumConverter.Instance}}"
                  IsHitTestVisible="{Binding HitTestVisible}"
                  Effect="{Binding DropShadow, Converter={x:Static converters:BoolToDropShadowEffectConverter.Instance}}">
                <ItemsControl ItemsSource="{Binding Locations}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <local:LocationControl Margin="2"
                                                   HorizontalAlignment="Left"
                                                   Compact="{Binding DataContext.CompactDisplay, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="layout:ArrayPanel">
            <Grid Width="{Binding Width, Converter={x:Static converters:NegativeToNaNDoubleConverter.Instance}}"
                  Height="{Binding Height, Converter={x:Static converters:NegativeToNaNDoubleConverter.Instance}}"
                  Margin="{Binding Margin}"
                  Background="{Binding Background, Converter={x:Static converters:StringToBrushConverter.Instance}}"
                  HorizontalAlignment="{Binding HorizontalAlignment, Converter={x:Static converters:TrivialEnumConverter.Instance}}"
                  VerticalAlignment="{Binding VerticalAlignment, Converter={x:Static converters:TrivialEnumConverter.Instance}}"
                  IsHitTestVisible="{Binding HitTestVisible}"
                  Effect="{Binding DropShadow, Converter={x:Static converters:BoolToDropShadowEffectConverter.Instance}}">
                <ItemsControl ItemsSource="{Binding Children}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <!-- Orientation is bound via RelativeSource to the owning ItemsControl's DataContext (the ArrayPanel).
                                 TrivialEnumConverter maps EmoTracker.Data.Layout.Orientation → Avalonia.Layout.Orientation. -->
                            <StackPanel Orientation="{Binding DataContext.Orientation,
                                RelativeSource={RelativeSource AncestorType=ItemsControl},
                                Converter={x:Static converters:TrivialEnumConverter.Instance}}" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="layout:DockPanel">
            <Grid Width="{Binding Width, Converter={x:Static converters:NegativeToNaNDoubleConverter.Instance}}"
                  Height="{Binding Height, Converter={x:Static converters:NegativeToNaNDoubleConverter.Instance}}"
                  Margin="{Binding Margin}"
                  Background="{Binding Background, Converter={x:Static converters:StringToBrushConverter.Instance}}"
                  HorizontalAlignment="{Binding HorizontalAlignment, Converter={x:Static converters:TrivialEnumConverter.Instance}}"
                  VerticalAlignment="{Binding VerticalAlignment, Converter={x:Static converters:TrivialEnumConverter.Instance}}"
                  IsHitTestVisible="{Binding HitTestVisible}"
                  Effect="{Binding DropShadow, Converter={x:Static converters:BoolToDropShadowEffectConverter.Instance}}">
                <ItemsControl ItemsSource="{Binding Children}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <DockPanel LastChildFill="True" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerTheme>
                        <ControlTheme TargetType="ContentPresenter">
                            <Setter Property="(DockPanel.Dock)"
                                    Value="{Binding DockLocation, Converter={x:Static converters:StringToDockConverter.Instance}}" />
                        </ControlTheme>
                    </ItemsControl.ItemContainerTheme>
                </ItemsControl>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="layout:CanvasPanel">
            <Grid Width="{Binding Width, Converter={x:Static converters:NegativeToNaNDoubleConverter.Instance}}"
                  Height="{Binding Height, Converter={x:Static converters:NegativeToNaNDoubleConverter.Instance}}"
                  Margin="{Binding Margin}"
                  Background="{Binding Background, Converter={x:Static converters:StringToBrushConverter.Instance}}"
                  HorizontalAlignment="{Binding HorizontalAlignment, Converter={x:Static converters:TrivialEnumConverter.Instance}}"
                  VerticalAlignment="{Binding VerticalAlignment, Converter={x:Static converters:TrivialEnumConverter.Instance}}"
                  IsHitTestVisible="{Binding HitTestVisible}"
                  Effect="{Binding DropShadow, Converter={x:Static converters:BoolToDropShadowEffectConverter.Instance}}">
                <ItemsControl ItemsSource="{Binding Children}" ClipToBounds="True">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerTheme>
                        <ControlTheme TargetType="ContentPresenter">
                            <Setter Property="(Canvas.Left)"
                                    Value="{Binding CanvasX, Converter={x:Static converters:CanvasPositionConverter.Instance}}" />
                            <Setter Property="(Canvas.Top)"
                                    Value="{Binding CanvasY, Converter={x:Static converters:CanvasPositionConverter.Instance}}" />
                            <Setter Property="(Canvas.ZIndex)"
                                    Value="{Binding CanvasDepth, Converter={x:Static converters:CanvasZIndexConverter.Instance}}" />
                        </ControlTheme>
                    </ItemsControl.ItemContainerTheme>
                </ItemsControl>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="layout:ViewBox">
            <Grid Width="{Binding Width, Converter={x:Static converters:NegativeToNaNDoubleConverter.Instance}}"
                  Height="{Binding Height, Converter={x:Static converters:NegativeToNaNDoubleConverter.Instance}}"
                  Margin="{Binding Margin}"
                  HorizontalAlignment="{Binding HorizontalAlignment, Converter={x:Static converters:TrivialEnumConverter.Instance}}"
                  VerticalAlignment="{Binding VerticalAlignment, Converter={x:Static converters:TrivialEnumConverter.Instance}}"
                  IsHitTestVisible="{Binding HitTestVisible}"
                  Effect="{Binding DropShadow, Converter={x:Static converters:BoolToDropShadowEffectConverter.Instance}}">
                <Viewbox>
                    <ItemsControl ItemsSource="{Binding Items}" />
                </Viewbox>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="layout:TabPanel">
            <Grid Width="{Binding Width, Converter={x:Static converters:NegativeToNaNDoubleConverter.Instance}}"
                  Height="{Binding Height, Converter={x:Static converters:NegativeToNaNDoubleConverter.Instance}}"
                  Margin="{Binding Margin}"
                  HorizontalAlignment="{Binding HorizontalAlignment, Converter={x:Static converters:TrivialEnumConverter.Instance}}"
                  VerticalAlignment="{Binding VerticalAlignment, Converter={x:Static converters:TrivialEnumConverter.Instance}}"
                  IsHitTestVisible="{Binding HitTestVisible}"
                  Effect="{Binding DropShadow, Converter={x:Static converters:BoolToDropShadowEffectConverter.Instance}}">
                <TabControl ItemsSource="{Binding Tabs}"
                            Background="{x:Null}"
                            SelectedItem="{Binding CurrentTab, Mode=TwoWay}" />
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="layout:MapPanel">
            <Grid Width="{Binding Width, Converter={x:Static converters:NegativeToNaNDoubleConverter.Instance}}"
                  Height="{Binding Height, Converter={x:Static converters:NegativeToNaNDoubleConverter.Instance}}"
                  Margin="{Binding Margin}"
                  HorizontalAlignment="{Binding HorizontalAlignment, Converter={x:Static converters:TrivialEnumConverter.Instance}}"
                  VerticalAlignment="{Binding VerticalAlignment, Converter={x:Static converters:TrivialEnumConverter.Instance}}"
                  IsHitTestVisible="{Binding HitTestVisible}"
                  Effect="{Binding DropShadow, Converter={x:Static converters:BoolToDropShadowEffectConverter.Instance}}">
                <local:LocationMapControl />
            </Grid>
        </DataTemplate>

        <!-- GroupBox MUST be declared before Container because GroupBox inherits Container —
             Avalonia picks the first DataType match (inheritance-based), so the more-derived
             type's template must come first. -->
        <DataTemplate DataType="layout:GroupBox">
            <Grid Width="{Binding Width, Converter={x:Static converters:NegativeToNaNDoubleConverter.Instance}}"
                  Height="{Binding Height, Converter={x:Static converters:NegativeToNaNDoubleConverter.Instance}}"
                  Margin="{Binding Margin}"
                  HorizontalAlignment="{Binding HorizontalAlignment, Converter={x:Static converters:TrivialEnumConverter.Instance}}"
                  VerticalAlignment="{Binding VerticalAlignment, Converter={x:Static converters:TrivialEnumConverter.Instance}}"
                  IsHitTestVisible="{Binding HitTestVisible}"
                  Effect="{Binding DropShadow, Converter={x:Static converters:BoolToDropShadowEffectConverter.Instance}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <!-- Header bar -->
                <Grid Grid.Row="0"
                      Background="{Binding HeaderBackground, Converter={x:Static converters:StringToBrushConverter.Instance}, FallbackValue=#212121}">
                    <TextBlock Text="{Binding Header}" FontWeight="Bold" FontSize="12"
                               Foreground="WhiteSmoke"
                               Margin="10,5" />
                </Grid>
                <!-- Content area -->
                <Grid Grid.Row="1"
                      Background="{Binding Background, Converter={x:Static converters:StringToBrushConverter.Instance}, FallbackValue=#66212121}">
                    <ItemsControl ItemsSource="{Binding Items}" Margin="5" />
                </Grid>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="layout:Container">
            <Grid Width="{Binding Width, Converter={x:Static converters:NegativeToNaNDoubleConverter.Instance}}"
                  Height="{Binding Height, Converter={x:Static converters:NegativeToNaNDoubleConverter.Instance}}"
                  Margin="{Binding Margin}"
                  Background="{Binding Background, Converter={x:Static converters:StringToBrushConverter.Instance}}"
                  HorizontalAlignment="{Binding HorizontalAlignment, Converter={x:Static converters:TrivialEnumConverter.Instance}}"
                  VerticalAlignment="{Binding VerticalAlignment, Converter={x:Static converters:TrivialEnumConverter.Instance}}"
                  IsHitTestVisible="{Binding HitTestVisible}"
                  Effect="{Binding DropShadow, Converter={x:Static converters:BoolToDropShadowEffectConverter.Instance}}">
                <ItemsControl ItemsSource="{Binding Items}" />
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="layout:ScrollPanel">
            <Grid Width="{Binding Width, Converter={x:Static converters:NegativeToNaNDoubleConverter.Instance}}"
                  Height="{Binding Height, Converter={x:Static converters:NegativeToNaNDoubleConverter.Instance}}"
                  Margin="{Binding Margin}"
                  Background="{Binding Background, Converter={x:Static converters:StringToBrushConverter.Instance}}"
                  HorizontalAlignment="{Binding HorizontalAlignment, Converter={x:Static converters:TrivialEnumConverter.Instance}}"
                  VerticalAlignment="{Binding VerticalAlignment, Converter={x:Static converters:TrivialEnumConverter.Instance}}"
                  IsHitTestVisible="{Binding HitTestVisible}"
                  Effect="{Binding DropShadow, Converter={x:Static converters:BoolToDropShadowEffectConverter.Instance}}">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Items}" />
                </ScrollViewer>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="layout:ItemGrid">
            <Grid Width="{Binding Width, Converter={x:Static converters:NegativeToNaNDoubleConverter.Instance}}"
                  Height="{Binding Height, Converter={x:Static converters:NegativeToNaNDoubleConverter.Instance}}"
                  Margin="{Binding Margin}"
                  HorizontalAlignment="{Binding HorizontalAlignment, Converter={x:Static converters:TrivialEnumConverter.Instance}}"
                  VerticalAlignment="{Binding VerticalAlignment, Converter={x:Static converters:TrivialEnumConverter.Instance}}"
                  IsHitTestVisible="{Binding HitTestVisible}"
                  Effect="{Binding DropShadow, Converter={x:Static converters:BoolToDropShadowEffectConverter.Instance}}">
                <local:ItemGridControl DataContext="{Binding Data}" />
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="layout:Item">
            <Grid Width="{Binding Width, Converter={x:Static converters:NegativeToNaNDoubleConverter.Instance}}"
                  Height="{Binding Height, Converter={x:Static converters:NegativeToNaNDoubleConverter.Instance}}"
                  Margin="{Binding Margin}"
                  HorizontalAlignment="{Binding HorizontalAlignment, Converter={x:Static converters:TrivialEnumConverter.Instance}}"
                  VerticalAlignment="{Binding VerticalAlignment, Converter={x:Static converters:TrivialEnumConverter.Instance}}"
                  IsHitTestVisible="{Binding HitTestVisible}"
                  Effect="{Binding DropShadow, Converter={x:Static converters:BoolToDropShadowEffectConverter.Instance}}">
                <local:TrackableItemControl DataContext="{Binding Data}"
                                            IconWidth="{Binding DataContext.Width, RelativeSource={RelativeSource AncestorType=Grid}}"
                                            IconHeight="{Binding DataContext.Height, RelativeSource={RelativeSource AncestorType=Grid}}" />
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="layout:Image">
            <Grid Width="{Binding Width, Converter={x:Static converters:NegativeToNaNDoubleConverter.Instance}}"
                  Height="{Binding Height, Converter={x:Static converters:NegativeToNaNDoubleConverter.Instance}}"
                  Margin="{Binding Margin}"
                  HorizontalAlignment="{Binding HorizontalAlignment, Converter={x:Static converters:TrivialEnumConverter.Instance}}"
                  VerticalAlignment="{Binding VerticalAlignment, Converter={x:Static converters:TrivialEnumConverter.Instance}}"
                  IsHitTestVisible="{Binding HitTestVisible}"
                  Effect="{Binding DropShadow, Converter={x:Static converters:BoolToDropShadowEffectConverter.Instance}}">
                <Image Source="{Binding Content, Converter={x:Static converters:ImageReferenceConverter.Instance}}" />
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="layout:TextBlock">
            <Grid Width="{Binding Width, Converter={x:Static converters:NegativeToNaNDoubleConverter.Instance}}"
                  Height="{Binding Height, Converter={x:Static converters:NegativeToNaNDoubleConverter.Instance}}"
                  Margin="{Binding Margin}"
                  HorizontalAlignment="{Binding HorizontalAlignment, Converter={x:Static converters:TrivialEnumConverter.Instance}}"
                  VerticalAlignment="{Binding VerticalAlignment, Converter={x:Static converters:TrivialEnumConverter.Instance}}"
                  IsHitTestVisible="{Binding HitTestVisible}"
                  Effect="{Binding DropShadow, Converter={x:Static converters:BoolToDropShadowEffectConverter.Instance}}">
                <TextBlock Text="{Binding Text}" />
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="layout:LastClearedLocation">
            <ContentControl Content="{Binding Location}">
                <ContentControl.ContentTemplate>
                    <DataTemplate>
                        <local:LocationControl DataContext="{Binding LastClearedLocation, Source={x:Static data:LocationDatabase.Instance}}"
                                               Compact="{Binding DataContext.CompactDisplay, RelativeSource={RelativeSource Self}}" />
                    </DataTemplate>
                </ContentControl.ContentTemplate>
            </ContentControl>
        </DataTemplate>

        <DataTemplate DataType="layout:ButtonPopup">
            <Grid Width="{Binding Width, Converter={x:Static converters:NegativeToNaNDoubleConverter.Instance}}"
                  Height="{Binding Height, Converter={x:Static converters:NegativeToNaNDoubleConverter.Instance}}"
                  Margin="{Binding Margin}"
                  HorizontalAlignment="{Binding HorizontalAlignment, Converter={x:Static converters:TrivialEnumConverter.Instance}}"
                  VerticalAlignment="{Binding VerticalAlignment, Converter={x:Static converters:TrivialEnumConverter.Instance}}"
                  IsHitTestVisible="{Binding HitTestVisible}"
                  Effect="{Binding DropShadow, Converter={x:Static converters:BoolToDropShadowEffectConverter.Instance}}">
                <!-- ButtonPopup: rendered as a simple toggle button; full popup behaviour requires code-behind in Avalonia -->
                <controls:MouseOnlyToggleButton />
            </Grid>
        </DataTemplate>

    </UserControl.DataTemplates>

    <Grid>
        <Grid DataContext="{Binding Root}">
            <ContentControl Content="{Binding}" />
        </Grid>
    </Grid>
</UserControl>
