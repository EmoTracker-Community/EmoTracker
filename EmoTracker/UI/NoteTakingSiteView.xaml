<UserControl x:Class="EmoTracker.UI.NoteTakingSiteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EmoTracker.UI"
             xmlns:notesui="clr-namespace:EmoTracker.UI.Notes"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="ScrollBarThumb" TargetType="{x:Type Thumb}">
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="OverridesDefaultStyle" Value="true" />
            <Setter Property="IsTabStop" Value="false" />
            <Setter Property="Focusable" Value="false" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border CornerRadius="2" Background="DarkGray" BorderBrush="DarkGray" BorderThickness="1" Width="3" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="VerticalScrollBar" TargetType="{x:Type ScrollBar}">
            <Grid>
                <Track Name="PART_Track" Grid.Row="1" IsDirectionReversed="true">
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollBarThumb}" Margin="5,0,0,0" />
                    </Track.Thumb>                    
                </Track>
            </Grid>
        </ControlTemplate>

        <ControlTemplate x:Key="HorizontalScrollBar"
                 TargetType="{x:Type ScrollBar}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition MaxWidth="18" />
                    <ColumnDefinition Width="0.00001*" />
                    <ColumnDefinition MaxWidth="18" />
                </Grid.ColumnDefinitions>
                <Border Grid.ColumnSpan="3" CornerRadius="2" Background="#F0F0F0" />
                <Track Name="PART_Track" Grid.Column="1" IsDirectionReversed="False">
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollBarThumb}" Margin="0,1,0,1" />
                    </Track.Thumb>
                </Track>
            </Grid>
        </ControlTemplate>

        <Style x:Key="{x:Type ScrollBar}" TargetType="{x:Type ScrollBar}">
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="OverridesDefaultStyle" Value="true" />
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="Height" Value="6" />
                    <Setter Property="Template" Value="{StaticResource HorizontalScrollBar}" />
                </Trigger>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="Height" Value="Auto" />
                    <Setter Property="Template" Value="{StaticResource VerticalScrollBar}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="AddButton" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="3">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="DarkGray" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="WhiteSmoke" />
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock FontFamily="{StaticResource FontAwesome5Free}" FontSize="14" Text="&#xf0fe;" ToolTip="Remove" Foreground="#212121" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="3"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DeleteButton" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <TextBlock Background="Transparent" FontFamily="{StaticResource FontAwesome5Free}" FontSize="14" Text="&#xf2ed;" ToolTip="Delete this note" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="Red" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="False">
                                                <Setter Property="Foreground" Value="DarkGray" />
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>        
    </UserControl.Resources>
    <Grid>
        <Grid Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>
            <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <ItemsControl Name="NotesItemsControl"  MinWidth="100" ItemsSource="{Binding Notes}" Grid.IsSharedSizeScope="True">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid MinHeight="10" Margin="3,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="auto" SharedSizeGroup="MarkdownSection"/>
                                    <ColumnDefinition Width="auto" SharedSizeGroup="ItemsSection"/>
                                    <ColumnDefinition Width="auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,0,5,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Width="24" Height="24" Background="Transparent" ToolTip="No user profile selected">
                                        <Border CornerRadius="3" Background="Black" />
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="&#xf007;" FontFamily="{StaticResource FontAwesome5Free}" Foreground="DarkGray" />
                                        <Border CornerRadius="3" Background="Transparent" BorderBrush="DarkGray" BorderThickness="2" />
                                    </Grid>
                                    <Button Grid.Row="1" Style="{StaticResource DeleteButton}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="5,7,5,0" Click="DeleteNoteButton_Click"/>
                                </Grid>
                                <Grid Grid.Column="2">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Items, FallbackValue={x:Null}}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ItemsControl Grid.Column="0" ItemsSource="{Binding Items}" VerticalAlignment="Top">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Grid.Column="1" Margin="5,0,0,0" Orientation="Horizontal" FlowDirection="LeftToRight" MaxWidth="120" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Click="RemoveNoteItemButton_Click">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Grid Name="ItemHost" Background="Transparent">
                                                                <local:TrackableItemControl local:TrackableItemControl.DisplayPotentialIcon="True" Margin="3" IsEnabled="False"/>
                                                                <Border CornerRadius="3">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Background" Value="#88ff0000" />
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Setter Property="TextBlock.Foreground" Value="WhiteSmoke" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsMouseOver, ElementName=ItemHost}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <TextBlock FontFamily="{StaticResource FontAwesome5Free}" FontSize="9" Text="&#xf2ed;" ToolTip="Remove" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="2"/>
                                                                </Border>
                                                            </Grid>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <local:CapturableItemControl Grid.Column="1" Width="32" Height="32" VerticalAlignment="Top" Margin="3"/>
                                </Grid>
                                <notesui:MarkdownTextNoteControl Grid.Column="1" VerticalAlignment="Stretch" Margin="5,0" MaxWidth="300">
                                    <notesui:MarkdownTextNoteControl.Style>
                                        <Style TargetType="notesui:MarkdownTextNoteControl">
                                            <!--
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Document, FallbackValue={x:Null}}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                                -->
                                        </Style>
                                    </notesui:MarkdownTextNoteControl.Style>
                                </notesui:MarkdownTextNoteControl>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            <Grid Grid.Row="1">
                <Button Style="{StaticResource AddButton}" VerticalAlignment="Center" Click="AddNoteButton_Click" HorizontalAlignment="Stretch" Margin="3,8,3,5" ToolTip="Add a new note" />
            </Grid>
        </Grid>
    </Grid>
</UserControl>
