<UserControl x:Class="EmoTracker.UI.NoteTakingIconPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EmoTracker.UI"
             xmlns:controls="clr-namespace:EmoTracker.UI.Controls;assembly=EmoTracker.UI"
             xmlns:settings="clr-namespace:EmoTracker.Data.Settings;assembly=EmoTracker.Data"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Popup Name="NotesPopup" IsOpen="{Binding ElementName=OpenNotesButton, Path=IsChecked, Mode=TwoWay}" StaysOpen="{Binding ElementName=OpenNotesButton, Path=IsMouseOver}" Placement="Top"  HorizontalOffset="4" VerticalOffset="4" PlacementTarget="{Binding ElementName=OpenNotesButton}" PopupAnimation="Fade" AllowsTransparency="True" ClipToBounds="False">
            <Border Name="PopupRegion" BorderBrush="DarkGray" BorderThickness="3" Background="#FF212121" CornerRadius="5" Margin="20">
                <Border.Effect>
                    <DropShadowEffect Opacity="0.8" BlurRadius="20" ShadowDepth="3"/>
                </Border.Effect>
                <local:NoteTakingSiteView Margin="5" />
            </Border>
        </Popup>
        <controls:MouseOnlyToggleButton Name="OpenNotesButton">
            <controls:MouseOnlyToggleButton.Template>
                <ControlTemplate TargetType="controls:MouseOnlyToggleButton">
                    <TextBlock Name="Icon" FontFamily="{StaticResource FontAwesome5Free}" Text="&#xf044;" ToolTip="View and edit notes" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="WhiteSmoke" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Empty}" Value="false">
                                        <Setter Property="Foreground" Value="{Binding Status_Generic_Active, Source={x:Static settings:ApplicationColors.Instance}}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="false">
                            <Setter TargetName="Icon" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </controls:MouseOnlyToggleButton.Template>
        </controls:MouseOnlyToggleButton>
    </Grid>
</UserControl>
