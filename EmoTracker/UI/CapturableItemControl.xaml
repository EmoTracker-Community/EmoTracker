<UserControl x:Class="EmoTracker.UI.CapturableItemControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:app="clr-namespace:EmoTracker"
             xmlns:converters="clr-namespace:EmoTracker.UI.Converters;assembly=EmoTracker.UI"
             xmlns:local="clr-namespace:EmoTracker.UI"
             xmlns:data="clr-namespace:EmoTracker.Data"
             mc:Ignorable="d" 
             d:DesignHeight="32" d:DesignWidth="32" Background="Transparent">
    <UserControl.Resources>
        <ItemsPanelTemplate x:Key="VerticalItemsPanel">
            <WrapPanel Orientation="Vertical" SnapsToDevicePixels="True"/>
        </ItemsPanelTemplate>
        <ItemsPanelTemplate x:Key="HorizontalItemsPanel">
            <WrapPanel Orientation="Horizontal" />
        </ItemsPanelTemplate>
        <DataTemplate x:Key="ItemTemplate">
            <Button Content="{Binding}" Command="{Binding RelativeSource={RelativeSource AncestorType=local:CapturableItemControl, Mode=FindAncestor}, Path=SelectItemCommand}" CommandParameter="{Binding}">
                <Button.InputBindings>
                    <MouseBinding Gesture="RightClick" Command="{Binding RelativeSource={RelativeSource AncestorType=local:CapturableItemControl, Mode=FindAncestor}, Path=ClearItemCommand}" />
                    <MouseBinding Gesture="RightDoubleClick" Command="{Binding RelativeSource={RelativeSource AncestorType=local:CapturableItemControl, Mode=FindAncestor}, Path=ClearItemCommand}" />
                </Button.InputBindings>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent" Margin="1,2">
                            <ContentPresenter />
                        </Grid>
                    </ControlTemplate>
                </Button.Template>
                <Button.ContentTemplate>
                    <DataTemplate>
                        <Image Source="{Binding PotentialIcon, Converter={x:Static converters:ImageReferenceConverter.Instance}}" Width="32" Height="32"/>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>
        </DataTemplate>        
    </UserControl.Resources>
    <Grid>
        <ToggleButton Name="SettingsToggle">
            <ToggleButton.Template>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Grid Width="32" Height="32">
                        <Image Source="{Binding CapturedItem.PotentialIcon, Converter={x:Static converters:ImageReferenceConverter.Instance}}" Width="32" Height="32"/>
                        <Grid Name="UnknownControl">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CapturedItem}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Rectangle RadiusX="4" RadiusY="4" Stroke="WhiteSmoke" StrokeThickness="2" StrokeDashArray="2 3" Fill="Transparent"/>
                        </Grid>
                    </Grid>
                </ControlTemplate>
            </ToggleButton.Template>
        </ToggleButton>
        <Popup Name="PopupInstance" IsOpen="{Binding ElementName=SettingsToggle, Path=IsChecked, Mode=TwoWay}" StaysOpen="{Binding ElementName=SettingsToggle, Path=IsMouseOver}" Placement="RelativePoint" HorizontalOffset="16" VerticalOffset="16" PlacementTarget="{Binding ElementName=SettingsToggle}" PopupAnimation="Fade" AllowsTransparency="True" ClipToBounds="False">
            <Border Name="PopupRegion" BorderBrush="DarkGray" BorderThickness="3" Background="#FF212121" CornerRadius="5" Margin="20">
                <Border.Effect>
                    <DropShadowEffect Opacity="0.8" BlurRadius="20" ShadowDepth="3"/>
                </Border.Effect>
                <StackPanel>
                    <local:LayoutControl DataContext="{Binding ItemCaptureLayout, Converter={x:Static converters:LayoutReferenceConverter.Instance}, ConverterParameter=tracker_capture_item }" local:TrackableItemControl.DisplayPotentialIcon="true" local:TrackableItemControl.DisplayCapturableOnly="true" local:TrackableItemControl.ClickHandler="{Binding RelativeSource={RelativeSource AncestorType=local:CapturableItemControl, Mode=FindAncestor}}"/>
                    <Grid HorizontalAlignment="Stretch" Margin="5,5,5,0" Height="1" Background="White" />
                    <Button Content="Clear" Command="{Binding RelativeSource={RelativeSource AncestorType=local:CapturableItemControl, Mode=FindAncestor}, Path=SelectItemCommand}" CommandParameter="{x:Null}" Margin="5">
                        <Button.InputBindings>
                            <MouseBinding Gesture="RightClick" Command="{Binding RelativeSource={RelativeSource AncestorType=local:CapturableItemControl, Mode=FindAncestor}, Path=ClearItemCommand}" />
                            <MouseBinding Gesture="RightDoubleClick" Command="{Binding RelativeSource={RelativeSource AncestorType=local:CapturableItemControl, Mode=FindAncestor}, Path=ClearItemCommand}" />
                        </Button.InputBindings>
                    </Button>
                </StackPanel>                
            </Border>
        </Popup>
    </Grid>
</UserControl>
