<Window x:Class="EmoTracker.UI.PackageManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:app="clr-namespace:EmoTracker"
        xmlns:core="clr-namespace:EmoTracker.Core;assembly=EmoTracker.Core"
        xmlns:converters="clr-namespace:EmoTracker.UI.Converters;assembly=EmoTracker.UI"
        xmlns:local="clr-namespace:EmoTracker.UI"
        xmlns:data="clr-namespace:EmoTracker.Data"
        xmlns:packages="clr-namespace:EmoTracker.Data.Packages;assembly=EmoTracker.Data"
        xmlns:settings="clr-namespace:EmoTracker.Data.Settings;assembly=EmoTracker.Data"
        mc:Ignorable="d"
        Name="PackageManagerHost"
        SizeToContent="Width" ResizeMode="CanResizeWithGrip" Background="#212121" MinWidth="800" Height="600" WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <converters:FlagsEnumToBoolConverter x:Key="FlagsConverter" />
        <Style x:Key="SideBarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Command" Value="{Binding SetAvailablePackageViewFilterCommand, Source={x:Static app:ApplicationModel.Instance}}" />
            <Setter Property="TextBlock.Foreground" Value="WhiteSmoke" />
            <Setter Property="TextBlock.FontSize" Value="18" />
            <Setter Property="BorderBrush" Value="{x:Null}" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="{TemplateBinding VerticalContentAlignment}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsMouseOver" Value="false" />
                    </MultiTrigger.Conditions>
                    <MultiTrigger.Setters>
                        <Setter Property="TextBlock.Foreground" Value="#717171" />
                    </MultiTrigger.Setters>
                </MultiTrigger>
            </Style.Triggers>
        </Style>        
    </Window.Resources>
    <Window.Style>
        <Style TargetType="Window">
            <Setter Property="Title" Value="Package Manager" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding CommunityRepositoryListError, Source={x:Static packages:PackageManager.Instance}}" Value="true">
                    <Setter Property="Title" Value="Package Manager (Community Package Service is currently down)" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Style>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0" Grid.Row="1" Width="48">
            <StackPanel Orientation="Vertical" Margin="5">
                <Button ToolTip="All Packages" CommandParameter="All" Content="&#xf57d;" Width="24" HorizontalAlignment="Center" FontFamily="{StaticResource FontAwesome5Free}" Margin="0,5">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SideBarButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding AvailablePackageViewFilter, Source={x:Static app:ApplicationModel.Instance}}" Value="All">
                                    <Setter Property="TextBlock.Foreground" Value="{Binding Status_Generic_Active, Source={x:Static settings:ApplicationColors.Instance}}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button ToolTip="Installed Packages" CommandParameter="Installed"  Content="&#xf0c7;" Width="24" HorizontalAlignment="Center" FontFamily="{StaticResource FontAwesome5Free}" Margin="0,5">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SideBarButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding AvailablePackageViewFilter, Source={x:Static app:ApplicationModel.Instance}}" Value="Installed">
                                    <Setter Property="TextBlock.Foreground" Value="{Binding Status_Generic_Active, Source={x:Static settings:ApplicationColors.Instance}}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button ToolTip="Installed Packages With Updates" CommandParameter="InstalledAndHasUpdate"  Content="&#xf381;" Width="24" HorizontalAlignment="Center" FontFamily="{StaticResource FontAwesome5Free}" Margin="0,5">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SideBarButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding AvailablePackageViewFilter, Source={x:Static app:ApplicationModel.Instance}}" Value="InstalledAndHasUpdate">
                                    <Setter Property="TextBlock.Foreground" Value="{Binding Status_Generic_Active, Source={x:Static settings:ApplicationColors.Instance}}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Grid.Column="1">
            <Grid TextBlock.Foreground="WhiteSmoke" Grid.IsSharedSizeScope="True" MinHeight="50">
                <Grid Margin="10,10,10,5">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Repositories.Count, Source={x:Static packages:PackageManager.Instance}}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>                
                    <TextBlock Text="No package repositories are available" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>
                <ItemsControl ItemsSource="{Binding AvailablePackagesView.Groups, Source={x:Static app:ApplicationModel.Instance}}" Margin="0,10,10,5">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#444444" BorderThickness="2" CornerRadius="3" Margin="0,0,0,10">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#333339" />
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition />
                                        <RowDefinition />
                                    </Grid.RowDefinitions>
                                    <Grid Margin="10,5">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="auto"/>
                                            <RowDefinition Height="1"/>
                                            <RowDefinition />
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0" Margin="0,5">
                                            <Image HorizontalAlignment="Left" VerticalAlignment="Center" MaxHeight="60" Source="{Binding Name, Converter={x:Static converters:GameNameToActualGameImageConverter.Instance}}" />
                                            <TextBlock Grid.Row="0" FontSize="14" Text="{Binding Name}" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="20">
                                                <TextBlock.Effect>
                                                    <DropShadowEffect ShadowDepth="3" Direction="215" BlurRadius="5" Color="Black" />
                                                </TextBlock.Effect>
                                            </TextBlock>
                                        </Grid>
                                        <Grid Grid.Row="1" Background="WhiteSmoke" />
                                        <ItemsControl Grid.Row="2" ItemsSource="{Binding Items}" Margin="0,10,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type packages:PackageRepositoryEntry}">
                                                    <Grid Margin="0,5">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="auto"/>
                                                            <RowDefinition Height="auto"/>
                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="auto" SharedSizeGroup="PackageName"/>
                                                            <ColumnDefinition Width="auto" SharedSizeGroup="PackageAuthor"/>
                                                            <ColumnDefinition MinWidth="50" Width="*" />
                                                            <ColumnDefinition Width="auto" SharedSizeGroup="PackageStatus"/>
                                                            <ColumnDefinition Width="auto" SharedSizeGroup="PackageAction"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="auto" />
                                                                <ColumnDefinition Width="auto"/>
                                                                <ColumnDefinition Width="auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                                <TextBlock FontFamily="{StaticResource FontAwesome5Free}" Text="&#xf005;" Foreground="Goldenrod" VerticalAlignment="Center">
                                                                    <TextBlock.ToolTip>Official EmoTracker Package</TextBlock.ToolTip>
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="FrameworkElement">
                                                                            <Setter Property="Margin" Value="0,0,2,0" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Flags, Converter={StaticResource FlagsConverter}, ConverterParameter=Official}" Value="false">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <TextBlock FontFamily="{StaticResource FontAwesome5Free}" Text="&#xf004;" Foreground="Goldenrod" VerticalAlignment="Center">
                                                                    <TextBlock.ToolTip>Featured Package</TextBlock.ToolTip>
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="FrameworkElement">
                                                                            <Setter Property="Margin" Value="5,0,2,0" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Flags, Converter={StaticResource FlagsConverter}, ConverterParameter=Featured}" Value="false">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="5,0" VerticalAlignment="Center"/>
                                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                                <TextBlock FontFamily="{StaticResource FontAwesome5Free}" Text="&#xF279;" Foreground="#8cd98c" >
                                                                    <TextBlock.ToolTip>Maps</TextBlock.ToolTip>
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="FrameworkElement">
                                                                            <Setter Property="Margin" Value="5,0,0,0" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Flags, Converter={StaticResource FlagsConverter}, ConverterParameter=Map}" Value="false">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <TextBlock FontFamily="{StaticResource FontAwesome5Free}" Text="&#xf276;" Foreground="#ff5050" >
                                                                    <TextBlock.ToolTip>Pinned Locations</TextBlock.ToolTip>
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="FrameworkElement">
                                                                            <Setter Property="Margin" Value="5,0,0,0" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Flags, Converter={StaticResource FlagsConverter}, ConverterParameter=Pins}" Value="false">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <TextBlock FontFamily="{StaticResource FontAwesome5Free}" Text="&#xf4ad;" Foreground="#9a7fcc">
                                                                    <TextBlock.ToolTip>ChatHUD Optimized</TextBlock.ToolTip>
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="FrameworkElement">
                                                                            <Setter Property="Margin" Value="5,0,0,0" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Flags, Converter={StaticResource FlagsConverter}, ConverterParameter=ChatHUD}" Value="false">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <TextBlock FontFamily="{StaticResource FontAwesome5Free}" Text="&#xf544;" Foreground="#35e0b5">
                                                                    <TextBlock.ToolTip>Auto-Tracker Support</TextBlock.ToolTip>
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="FrameworkElement">
                                                                            <Setter Property="Margin" Value="5,0,0,0" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Flags, Converter={StaticResource FlagsConverter}, ConverterParameter=AutoTracker}" Value="false">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <TextBlock FontFamily="{StaticResource FontAwesome5Free}" Text="&#xf071;" Foreground="#ebd534">
                                                                    <TextBlock.ToolTip>This package makes use of potentially unsafe scripting functions. Proceed at your own risk.</TextBlock.ToolTip>
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="FrameworkElement">
                                                                            <Setter Property="Margin" Value="5,0,0,0" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Flags, Converter={StaticResource FlagsConverter}, ConverterParameter=Unsafe}" Value="false">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </Grid>
                                                        <TextBlock Grid.Column="1" Text="{Binding Author}" Margin="5,0" VerticalAlignment="Center" HorizontalAlignment="Center" FontStyle="Italic"/>
                                                        <ProgressBar Grid.Column="2" Height="5" IsEnabled="False" Margin="5,0" Value="{Binding DownloadProgress}">
                                                            <ProgressBar.Style>
                                                                <Style TargetType="ProgressBar">
                                                                </Style>
                                                            </ProgressBar.Style>
                                                        </ProgressBar>
                                                        <TextBlock Grid.Column="3" Margin="5,0" VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="Available" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Status}" Value="AppUpdateRequired">
                                                                            <Setter Property="Text" Value="Requires App Update" />
                                                                            <Setter Property="Foreground" Value="LightGray" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Development">
                                                                            <Setter Property="Text" Value="Dev" />
                                                                            <Setter Property="Foreground" Value="#afafaf" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Installed">
                                                                            <Setter Property="Text" Value="Installed" />
                                                                            <Setter Property="Foreground" Value="#00ff00" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}" Value="UpdateAvailable">
                                                                            <Setter Property="Text" Value="Update Available" />
                                                                            <Setter Property="Foreground" Value="Yellow" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}" Value="DownloadError">
                                                                            <Setter Property="Text" Value="Download Error" />
                                                                            <Setter Property="Foreground" Value="Red" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <Button Grid.Column="4" Margin="5,0" ToolTip="{Binding Content, RelativeSource={RelativeSource Self}}" TextBlock.Foreground="Black">
                                                            <Button.ContentTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Text="{Binding }" Margin="3,2" />
                                                                </DataTemplate>
                                                            </Button.ContentTemplate>
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Setter Property="MinWidth" Value="60" />
                                                                    <Setter Property="Content" Value="Install" />
                                                                    <Setter Property="CommandParameter" Value="{Binding }" />
                                                                    <Setter Property="Command" Value="{Binding InstallPackageCommand, Source={x:Static app:ApplicationModel.Instance}}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Status}" Value="AppUpdateRequired">
                                                                            <Setter Property="Content" Value="Upgrade First" />
                                                                            <Setter Property="IsEnabled" Value="False" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Development">
                                                                            <Setter Property="IsEnabled" Value="False" />
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>                                                                        
                                                                        <DataTrigger Binding="{Binding Status}" Value="Installed">
                                                                            <Setter Property="Content" Value="Uninstall" />
                                                                            <Setter Property="Command" Value="{Binding UninstallPackageCommand, Source={x:Static app:ApplicationModel.Instance}}" />
                                                                        </DataTrigger>
                                                                        <MultiDataTrigger>
                                                                            <MultiDataTrigger.Conditions>
                                                                                <Condition Binding="{Binding Status}" Value="Installed" />
                                                                                <Condition Binding="{Binding IsShiftHeld, ElementName=PackageManagerHost}" Value="True" />
                                                                            </MultiDataTrigger.Conditions>
                                                                            <Setter Property="Content" Value="Reinstall" />
                                                                            <Setter Property="Command" Value="{Binding InstallPackageCommand, Source={x:Static app:ApplicationModel.Instance}}" />
                                                                        </MultiDataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}" Value="UpdateAvailable">
                                                                            <Setter Property="Content" Value="Update" />
                                                                            <Setter Property="Command" Value="{Binding InstallPackageCommand, Source={x:Static app:ApplicationModel.Instance}}" />
                                                                        </DataTrigger>
                                                                        <MultiDataTrigger>
                                                                            <MultiDataTrigger.Conditions>
                                                                                <Condition Binding="{Binding Status}" Value="UpdateAvailable" />
                                                                                <Condition Binding="{Binding IsShiftHeld, ElementName=PackageManagerHost}" Value="True" />
                                                                            </MultiDataTrigger.Conditions>
                                                                            <Setter Property="Content" Value="Uninstall" />
                                                                            <Setter Property="Command" Value="{Binding UninstallPackageCommand, Source={x:Static app:ApplicationModel.Instance}}" />
                                                                        </MultiDataTrigger>
                                                                        <DataTrigger Binding="{Binding DownloadNotInProgress, Source={x:Static packages:PackageManager.Instance}}" Value="False">
                                                                            <Setter Property="IsEnabled" Value="False" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                        <Grid Grid.Row="1" Grid.ColumnSpan="8" Margin="0,5,0,0">
                                                            <Grid.Style>
                                                                <Style TargetType="Grid">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Variants.Count}" Value="0">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Grid.Style>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="auto"/>
                                                                <RowDefinition />
                                                            </Grid.RowDefinitions>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="auto"/>
                                                                <ColumnDefinition />
                                                            </Grid.ColumnDefinitions>
                                                            <Grid Grid.Row="0" Grid.ColumnSpan="3" Height="1" Background="#888888" Margin="0,0,0,10" />
                                                            <Grid Grid.Row="1" Grid.Column="0" Width="10">
                                                                <Grid.Background>
                                                                    <LinearGradientBrush >
                                                                        <GradientStop Color="#BF666666"/>
                                                                        <GradientStop Color="#00666666" Offset="1"/>
                                                                    </LinearGradientBrush>
                                                                </Grid.Background>
                                                            </Grid>
                                                            <ItemsControl Grid.Row="1" Grid.Column="1" ItemsSource="{Binding Variants}" Margin="0,0,0,5">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Grid Margin="5">
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="auto"/>
                                                                                <ColumnDefinition Width="auto"/>
                                                                                <ColumnDefinition Width="auto"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                                                <TextBlock FontFamily="{StaticResource FontAwesome5Free}" Text="&#xf005;" Foreground="Goldenrod" VerticalAlignment="Center">
                                                                                    <TextBlock.ToolTip>Official EmoTracker Package</TextBlock.ToolTip>
                                                                                    <TextBlock.Style>
                                                                                        <Style TargetType="FrameworkElement">
                                                                                            <Setter Property="Margin" Value="5,0,2,0" />
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding Flags, Converter={StaticResource FlagsConverter}, ConverterParameter=Official}" Value="false">
                                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </TextBlock.Style>
                                                                                </TextBlock>
                                                                                <TextBlock FontFamily="{StaticResource FontAwesome5Free}" Text="&#xf004;" Foreground="Goldenrod" VerticalAlignment="Center">
                                                                                    <TextBlock.ToolTip>Featured Package</TextBlock.ToolTip>
                                                                                    <TextBlock.Style>
                                                                                        <Style TargetType="FrameworkElement">
                                                                                            <Setter Property="Margin" Value="5,0,2,0" />
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding Flags, Converter={StaticResource FlagsConverter}, ConverterParameter=Featured}" Value="false">
                                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </TextBlock.Style>
                                                                                </TextBlock>
                                                                            </StackPanel>
                                                                            <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="5,0" VerticalAlignment="Center"/>
                                                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                                                <TextBlock FontFamily="{StaticResource FontAwesome5Free}" Text="&#xF279;" Foreground="#8cd98c" >
                                                                                    <TextBlock.ToolTip>Maps</TextBlock.ToolTip>
                                                                                    <TextBlock.Style>
                                                                                        <Style TargetType="FrameworkElement">
                                                                                            <Setter Property="Margin" Value="5,0,0,0" />
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding Flags, Converter={StaticResource FlagsConverter}, ConverterParameter=Map}" Value="false">
                                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </TextBlock.Style>
                                                                                </TextBlock>
                                                                                <TextBlock FontFamily="{StaticResource FontAwesome5Free}" Text="&#xf276;" Foreground="#ff5050" >
                                                                                    <TextBlock.ToolTip>Pinned Locations</TextBlock.ToolTip>
                                                                                    <TextBlock.Style>
                                                                                        <Style TargetType="FrameworkElement">
                                                                                            <Setter Property="Margin" Value="5,0,0,0" />
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding Flags, Converter={StaticResource FlagsConverter}, ConverterParameter=Pins}" Value="false">
                                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </TextBlock.Style>
                                                                                </TextBlock>
                                                                                <TextBlock FontFamily="{StaticResource FontAwesome5Free}" Text="&#xf4ad;" Foreground="#9a7fcc">
                                                                                    <TextBlock.ToolTip>ChatHUD Optimized</TextBlock.ToolTip>
                                                                                    <TextBlock.Style>
                                                                                        <Style TargetType="FrameworkElement">
                                                                                            <Setter Property="Margin" Value="5,0,0,0" />
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding Flags, Converter={StaticResource FlagsConverter}, ConverterParameter=ChatHUD}" Value="false">
                                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </TextBlock.Style>
                                                                                </TextBlock>
                                                                                <TextBlock FontFamily="{StaticResource FontAwesome5Free}" Text="&#xf544;" Foreground="#35e0b5">
                                                                                    <TextBlock.ToolTip>Auto-Tracker Support</TextBlock.ToolTip>
                                                                                    <TextBlock.Style>
                                                                                        <Style TargetType="FrameworkElement">
                                                                                            <Setter Property="Margin" Value="5,0,0,0" />
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding Flags, Converter={StaticResource FlagsConverter}, ConverterParameter=AutoTracker}" Value="false">
                                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </TextBlock.Style>
                                                                                </TextBlock>
                                                                            </StackPanel>
                                                                        </Grid>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </Grid>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>
        <Grid Grid.Row="0" Background="#252030" Grid.ColumnSpan="2">
            <Grid.Effect>
                <DropShadowEffect BlurRadius="40"/>
            </Grid.Effect>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <TextBlock Foreground="WhiteSmoke" Text="Search Packages" VerticalAlignment="Center" Margin="15,0,10,0"/>
            <Border CornerRadius="10" Background="#e8e8e8" Margin="5,5,10,5" Grid.Column="1" BorderBrush="#d0d0d0" BorderThickness="2">
                <TextBox BorderBrush="{x:Null}" Background="Transparent" Margin="8,2" FontSize="10" VerticalAlignment="Center" Text="{Binding PackFilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=500, Source={x:Static app:ApplicationModel.Instance}}">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"/>
                            <Setter Property="BorderBrush" Value="{x:Null}"/>
                            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="KeyboardNavigation.TabNavigation" Value="None"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="AllowDrop" Value="true"/>
                            <Setter Property="ScrollViewer.PanningMode" Value="VerticalFirst"/>
                            <Setter Property="Stylus.IsFlicksEnabled" Value="False"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type TextBox}">
                                        <Border Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                                            <ScrollViewer Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsEnabled" Value="false">
                                                <Setter Property="Opacity" TargetName="border" Value="0.56"/>
                                            </Trigger>
                                            <!--
                                            <Trigger Property="IsMouseOver" Value="true">
                                                <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource TextBox.MouseOver.Border}"/>
                                            </Trigger>
                                            <Trigger Property="IsKeyboardFocused" Value="true">
                                                <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource TextBox.Focus.Border}"/>
                                            </Trigger>
                                            -->
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsInactiveSelectionHighlightEnabled" Value="true"/>
                                        <Condition Property="IsSelectionActive" Value="false"/>
                                    </MultiTrigger.Conditions>
                                    <Setter Property="SelectionBrush" Value="{DynamicResource {x:Static SystemColors.InactiveSelectionHighlightBrushKey}}"/>
                                </MultiTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </Border>
        </Grid>
    </Grid>
</Window>
