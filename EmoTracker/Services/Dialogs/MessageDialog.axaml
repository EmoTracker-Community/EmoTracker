<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EmoTracker.Services.Dialogs.MessageDialog"
        Title="EmoTracker"
        SizeToContent="WidthAndHeight"
        MinWidth="380" MaxWidth="600"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="#212121">

    <!-- Three-row layout matches CfaWarningWindow / ApplicationIsUpToDateWindow
         so all in-app modals share the same visual rhythm: dark band header,
         lighter content body, dark band footer with right-aligned buttons. -->
    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header — title only. Subtitle isn't needed for the simple
             OK/YesNo dialogs we use; can be added later if a richer call
             site needs it. -->
        <Border Grid.Row="0" Background="#252030" Padding="20,16">
            <TextBlock x:Name="TitleText"
                       Foreground="WhiteSmoke"
                       FontSize="15"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap" />
        </Border>

        <!-- Body — SelectableTextBlock so users can highlight + copy the
             message via Ctrl+C. This is the core fix for #68: MsBox.Avalonia
             v3.0.0-rc2's modal-window text control crashed the app on
             Ctrl+C because its child TextBlock reached for a clipboard
             impl that wasn't initialized for the modal's TopLevel. As a
             real Avalonia Window (= TopLevel), our dialog has a properly
             wired Clipboard, and SelectableTextBlock's standard Ctrl+C
             handler routes through it cleanly. -->
        <Border Grid.Row="1" Background="#1a1a1a" Padding="20,16">
            <SelectableTextBlock x:Name="MessageText"
                                 Foreground="#c8c8c8"
                                 FontSize="12"
                                 TextWrapping="Wrap"
                                 SelectionBrush="#264F78"
                                 SelectionForegroundBrush="WhiteSmoke" />
        </Border>

        <!-- Footer — buttons populated in code-behind based on
             MessageDialogButtons. Right-aligned with consistent spacing.
             The default action's button is styled with the #35e0b5 mint
             accent (matches CfaWarningWindow.OkButton); secondary actions
             get a flat dark style that doesn't compete for attention. -->
        <Border Grid.Row="2" Background="#252030" Padding="16,12">
            <StackPanel x:Name="ButtonRow"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8" />
        </Border>

    </Grid>
</Window>
