<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EmoTracker.App"
             Name="EmoTracker"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />
        <!-- WPF layout containers don't clip children by default. Pack makers rely on negative
             margins to intentionally overflow elements (e.g. close buttons positioned outside
             their containing box). Override ClipToBounds on every possible panel/control type
             to match WPF behaviour throughout the layout tree.
             
             NOTE: Avalonia's TemplatedControl sets ClipToBounds=True via OverrideDefaultValue
             in its static constructor. Plain type selectors (e.g. "ContentControl") only match
             the exact type, NOT derived types. Using ":is()" selectors to match the base type
             and all subclasses so that UserControl, custom controls, etc. are all covered. -->
        <Style Selector=":is(Panel)">
            <Setter Property="ClipToBounds" Value="False"/>
        </Style>
        <Style Selector=":is(TemplatedControl)">
            <Setter Property="ClipToBounds" Value="False"/>
        </Style>
        <Style Selector=":is(ContentPresenter)">
            <Setter Property="ClipToBounds" Value="False"/>
        </Style>
        <Style Selector=":is(Decorator)">
            <Setter Property="ClipToBounds" Value="False"/>
        </Style>
        <Style Selector=":is(Viewbox)">
            <Setter Property="ClipToBounds" Value="False"/>
        </Style>
        <Style Selector=":is(ItemsPresenter)">
            <Setter Property="ClipToBounds" Value="False"/>
        </Style>
    </Application.Styles>

    <Application.Resources>
        <FontFamily x:Key="FontAwesome5Free">avares://EmoTracker/Resources/Fonts#Font Awesome 5 Free Solid</FontFamily>
        <FontFamily x:Key="FontAwesome5Brands">avares://EmoTracker/Resources/Fonts#Font Awesome 5 Brands Regular</FontFamily>
    </Application.Resources>


</Application>
