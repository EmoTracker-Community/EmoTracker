<UserControl x:Class="EmoTracker.Extensions.VoiceRecognition.VoiceRecognitionStatusIndicator"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:data="clr-namespace:EmoTracker.Data;assembly=EmoTracker.Data"
             xmlns:local="clr-namespace:EmoTracker.Extensions.NDI"
             xmlns:settings="clr-namespace:EmoTracker.Data.Settings;assembly=EmoTracker.Data"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="Transparent">
        <Grid.Style>
            <Style TargetType="Grid">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding EnableVoiceControl, Source={x:Static data:ApplicationSettings.Instance}}" Value="false">
                        <Setter Property="Visibility" Value="Collapsed" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>
        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Active" IsCheckable="True" IsChecked="{Binding Active}" />
            </ContextMenu>
        </Grid.ContextMenu>
        <TextBlock FontFamily="{DynamicResource FontAwesome5Free}" VerticalAlignment="Center">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="WhiteSmoke" />
                    <Setter Property="Text" Value="&#xf130;" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Listening}" Value="True">
                            <Setter Property="Foreground" Value="{Binding Status_Generic_Active, Source={x:Static settings:ApplicationColors.Instance}}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Active}" Value="False">
                            <Setter Property="Text" Value="&#xf131;" />
                        </DataTrigger>                        
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>        
    </Grid>
</UserControl>
