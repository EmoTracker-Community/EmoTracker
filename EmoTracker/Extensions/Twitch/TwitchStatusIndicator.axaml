<UserControl x:Class="EmoTracker.Extensions.Twitch.TwitchStatusIndicator"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:EmoTracker.Extensions.Twitch"
             mc:Ignorable="d">
    <Grid Background="Transparent" ToolTip.Tip="{Binding ConnectionState}">
        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Connect" Command="{Binding ConnectCommand}"/>
                <MenuItem Header="Disconnect" Command="{Binding DisconnectCommand}"/>
            </ContextMenu>
        </Grid.ContextMenu>
        <!-- Foreground is set in code-behind based on ConnectionState -->
        <TextBlock Name="StatusIcon"
                   FontFamily="avares://EmoTracker/Resources/Fonts#Font Awesome 5 Brands Regular"
                   Text="&#xf1e8;"
                   Foreground="#717171"
                   VerticalAlignment="Center"/>
    </Grid>
</UserControl>
