<UserControl x:Class="EmoTracker.Extensions.Twitch.TwitchStatusIndicator"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EmoTracker.Extensions.Twitch"
             xmlns:settings="clr-namespace:EmoTracker.Data.Settings;assembly=EmoTracker.Data"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid Background="Transparent" ToolTip="{Binding ConnectionState}">
        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Connect" Command="{Binding ConnectCommand}"/>
                <MenuItem Header="Disconnect" Command="{Binding DisconnectCommand}"/>
            </ContextMenu>
        </Grid.ContextMenu>
        <TextBlock FontFamily="{StaticResource FontAwesome5Brands}" Text="&#xf1e8;" VerticalAlignment="Center">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="WhiteSmoke" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ConnectionState}" Value="Connected">
                            <Setter Property="Foreground" Value="{Binding Status_Generic_Success, Source={x:Static settings:ApplicationColors.Instance}}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ConnectionState}" Value="Connecting">
                            <Setter Property="Foreground" Value="{Binding Status_Generic_Warning, Source={x:Static settings:ApplicationColors.Instance}}" />
                        </DataTrigger>                        
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
    </Grid>
</UserControl>
