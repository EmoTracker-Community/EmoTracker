<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <ProjectGuid>{8B95A4E0-8F5B-4894-B1A4-945E20C989E8}</ProjectGuid>
    <OutputType>Library</OutputType>
    <RootNamespace>EmoTracker.Data</RootNamespace>
    <AssemblyName>EmoTracker.Data</AssemblyName>
    <TargetFramework>net10.0</TargetFramework>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <!-- Phase 1: emit generated sources to disk so they're inspectable in obj/Generated. -->
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
    <CompilerGeneratedFilesOutputPath>$(BaseIntermediateOutputPath)Generated</CompilerGeneratedFilesOutputPath>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\EmoTracker.Core\EmoTracker.Core.csproj" />
    <!--
      Source generator that emits the partial-property bodies for [KVImmutable] /
      [KVMutable] / [KVTransactable]. Referenced as an Analyzer so its output gets
      compiled into this project; ReferenceOutputAssembly=false so the generator's
      own assembly does not become a runtime dependency.
    -->
    <ProjectReference Include="..\EmoTracker.SourceGenerators\EmoTracker.SourceGenerators.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
    <PackageReference Include="NLua" Version="1.7.8" />
  </ItemGroup>

</Project>
